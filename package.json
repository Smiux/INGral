{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint",
    "check:fix": "npm run typecheck && npm run lint:fix",
    "preview": "vite preview"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.57.4",
    "@tiptap/core": "^3.14.0",
    "@tiptap/extension-bubble-menu": "^3.15.3",
    "@tiptap/extension-character-count": "^3.14.0",
    "@tiptap/extension-code-block": "^3.14.0",
    "@tiptap/extension-code-block-lowlight": "^3.14.0",
    "@tiptap/extension-drag-handle": "^3.15.3",
    "@tiptap/extension-drag-handle-react": "^3.15.3",
    "@tiptap/extension-floating-menu": "^3.15.3",
    "@tiptap/extension-image": "^3.14.0",
    "@tiptap/extension-invisible-characters": "^3.14.0",
    "@tiptap/extension-list": "^3.14.0",
    "@tiptap/extension-mathematics": "^3.15.1",
    "@tiptap/extension-node-range": "^3.15.3",
    "@tiptap/extension-subscript": "^3.14.0",
    "@tiptap/extension-superscript": "^3.14.0",
    "@tiptap/extension-table": "^3.15.1",
    "@tiptap/extension-text-align": "^3.14.0",
    "@tiptap/extension-text-style": "^3.15.0",
    "@tiptap/extension-typography": "^3.14.0",
    "@tiptap/extensions": "^3.14.0",
    "@tiptap/markdown": "^3.14.0",
    "@tiptap/pm": "^3.14.0",
    "@tiptap/react": "^3.14.0",
    "@tiptap/starter-kit": "^3.14.0",
    "@types/highlight.js": "^9.12.4",
    "@uiw/react-md-editor": "^4.0.9",
    "@xyflow/react": "^12.10.0",
    "dompurify": "^3.3.1",
    "elkjs": "^0.11.0",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.4",
    "katex": "^0.16.25",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.344.0",
    "markdown-it": "^14.1.0",
    "mathlive": "^0.108.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.9.6",
    "web-worker": "^1.5.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.23",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "eslint-plugin-unused-imports": "^4.3.0",
    "globals": "^15.9.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "ts-prune": "^0.10.3",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
