{
  "$schema": "https://raw.githubusercontent.com/SchemaStore/schemastore/master/src/schemas/json/package.json",
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 100",
    "lint:fix": "eslint . --ext ts,tsx --fix --report-unused-disable-directives --max-warnings 100",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint",
    "check:fix": "npm run typecheck && npm run lint:fix",
    "preview": "vite preview",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:list": "node scripts/db-debug-tool.js list-tables",
    "db:describe": "node scripts/db-debug-tool.js describe",
    "db:view": "node scripts/db-debug-tool.js view-data",
    "db:migrations": "node scripts/db-debug-tool.js list-migrations",
    "db:migrate": "node scripts/db-debug-tool.js run-migrations",
    "db:functions": "node scripts/db-debug-tool.js functions",
    "db:triggers": "node scripts/db-debug-tool.js triggers",
    "db:indexes": "node scripts/db-debug-tool.js indexes",
    "db:all": "node scripts/db-debug-tool.js all",
    "db:help": "node scripts/db-debug-tool.js help"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@mermaid-js/mermaid-cli": "^11.12.0",
    "@supabase/supabase-js": "^2.57.4",
    "@types/highlight.js": "^9.12.4",
    "@types/react-dropzone": "^4.2.2",
    "@types/three": "^0.181.0",
    "@uiw/react-md-editor": "^4.0.9",
    "chart.js": "^4.5.1",
    "date-fns": "^4.1.0",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.4",
    "katex": "^0.16.25",
    "lucide-react": "^0.344.0",
    "markdown-it": "^14.1.0",
    "mathquill": "^0.10.1-a",
    "mermaid": "^11.12.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.8",
    "react-easy-crop": "^5.5.5",
    "react-router-dom": "^7.9.6",
    "react-window": "^2.2.3",
    "reactflow": "^11.11.4",
    "three": "^0.181.2",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "@eslint/js": "^9.9.1",
    "@jest/globals": "^30.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/jest-axe": "^3.5.9",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "axe-core": "^4.11.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.2.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "pg": "^8.16.3",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.4.6",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vite-plugin-pwa": "^1.1.0"
  }
}
