# Supabase配置示例
VITE_SUPABASE_URL=https://your-supabase-url.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_anon_key_here
# 注意：Service Role Key不应提交到代码仓库
# VITE_SUPABASE_SERVICE_ROLE_KEY=sk_your_service_role_key_here

# 本地数据库配置（用于开发环境）
VITE_DATABASE_URL=postgresql://postgres:@localhost:5432/example_db
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432